# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:8080,https://your-lovable-app.lovable.app

# Hardcoded admin Firebase UIDs (comma-separated). Must match
# ADMIN_UIDS in src/lib/firebase.ts on the frontend.
